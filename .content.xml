<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:rep="internal" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Author Bio"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[core.wcm.components.teaser.v1.editor,teaserLightbox_dialog,ewcmams.components.authorbio.editor]"
    helpPath="https://www.adobe.com/go/aem_cmp_teaser_v1"
    trackingFeature="core-components:teaser:v1"
    width="40rem">
    <content
        granite:class="cmp-teaser__editor"
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <text
                        jcr:primaryType="nt:unstructured"
                        jcr:title="General"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <avatarAltText
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Avatar Alt Text "
                                                name="./avatarAltText"/>
                                            <authorCfPaths
                                                jcr:primaryType="nt:unstructured"
                                                granite:class="authorbio-multifield-validation"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                                fieldLabel="Author Bio Fragment Paths"
                                                fieldDescription="Add 1 to 3 author content fragment paths."
                                                composite="{Boolean}false"
                                                validation="authorbio-multifield-validation">
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    min-items="{Long}1"
                                                    max-items="{Long}3"/>
                                                <field
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathbrowser"
                                                    name="./authorCfPaths"
                                                    rootPath="/content/dam"/>
                                            </authorCfPaths>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </text>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>

package com.centurylink.aem.core.utils;

import org.apache.commons.codec.digest.DigestUtils;
import org.apache.commons.lang3.StringUtils;

/**
 * Utility class for Adobe Client Data Layer operations.
 * Provides methods for generating component IDs and other data layer utilities.
 */
public final class DataLayerUtil {

    /**
     * Separator used in component IDs.
     */
    private static final String ID_SEPARATOR = "-";

    /**
     * Length of the ID hash.
     */
    private static final int ID_HASH_LENGTH = 10;

    private DataLayerUtil() {
        // Utility class - prevent instantiation
    }

    /**
     * Generates a unique component ID for the data layer.
     * Format: "componentName-hash" (e.g., "navlink-e323ad2a28")
     *
     * @param componentName The name of the component (e.g., "navlink", "button")
     * @param resourcePath The path of the resource
     * @return A unique component ID
     */
    public static String generateId(String componentName, String resourcePath) {
        if (componentName == null || resourcePath == null) {
            throw new IllegalArgumentException("Component name and resource path cannot be null");
        }
        String hash = StringUtils.substring(DigestUtils.sha256Hex(resourcePath), 0, ID_HASH_LENGTH);
        return StringUtils.join(componentName, ID_SEPARATOR, hash);
    }

    /**
     * Converts the passed String to lowercase if it's not null.
     *
     * @param str The string to transform
     * @return Lowercase string or null if input is null
     */
    public static String transformValForAnalytics(String str) {
        return str != null ? str.toLowerCase() : null;
    }

    /**
     * Converts the passed String to lowercase and replace dashes with spaces if it's not null.
     *
     * @param str The string to transform
     * @return Transformed string or null if input is null
     */
    public static String transformTitleValForAnalytics(String str) {
        return str != null ? transformValForAnalytics(str).replace("-", " ") : null;
    }

}


